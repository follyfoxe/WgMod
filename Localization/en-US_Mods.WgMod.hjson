Items: {
	WeightManipulator: {
		DisplayName: Weight Manipulator
		Tooltip:
			'''
			Left Click to increase weight.
			Right Click to decrease.
			'''
	}

	Treadmill: {
		DisplayName: Treadmill
		Tooltip: Time to lose all that excess fat... maybe.
	}

	ExoskeletonLegs: {
		DisplayName: Exoskeleton Legs
		Tooltip:
			'''
			Allows flight
			The wearer can run super fast
			Reduces the movement penalty from high weights!
			'''
	}

	TerraskeletonLegs: {
		DisplayName: Terraskeleton Legs
		Tooltip:
			'''
			Allows flight, super fast running, and extra mobility on ice
			8% increased movement speed
			Provides the ability to walk on water, honey & lava
			Grants immunity to fire blocks and 7 seconds of immunity to lava
			Reduces damage from touching lava
			Greatly reduces the movement penalty from high weights!
			'''
	}

	FlaskOfAmbrosia: {
		DisplayName: Flask Of Ambrosia
		Tooltip:
			'''
			A powerful yet profoundly fattening drink
			Increases your movement speed, acceleration, regeneration, and defense upon taking damage!
			Effects scale with your obesity
			'''
	}

	QueenlyGluttony: {
		DisplayName: Queenly Gluttony
		Tooltip:
			'''
			Increases melee damage, critical strike chance, and armor penetration
			Decreases melee speed
			Melee attacks inflict pretty sparkle slime!
			Effects scale with your obesity
			'''
	}

	BottomlessAppetite: {
		DisplayName: Bottomless Appetite
		Tooltip:
			'''
			Creates a black hole around you, sucking in items from afar
			Enemies within the black hole suffer the wrath of the pillars
			Effects scale [c/FF0000:exponentially] with your obesity
			'Your hunger knows no bounds'
			'''
	}

	VacuumSkirt: {
		DisplayName: Vacuum Skirt
		Tooltip:
			'''
			Increases attack speed by {0}%
			{1} increased maximum life
			{2} increased defense
			{3}% reduced damage taken
			Movement effects of fatness are {4}% more punishing
			Effects scale with your obesity
			'''
	}

	VacuumHelmet: {
		DisplayName: Vacuum Helmet
		Tooltip:
			'''
			Increases critical strike chance by {0}%
			{1} increased maximum life
			{2} increased defense
			{3}% reduced damage taken
			Movement effects of fatness are {4}% more punishing
			Effects scale with your obesity
			'''
		SetBonus:
			'''
			{0} life regenerated per second
			{1}% increased maximum life
			Losing weight is {2}% harder
			'''
	}

	VacuumCrop: {
		DisplayName: Vacuum Crop
		Tooltip:
			'''
			Increases damage by {0}%
			{1} increased maximum life
			{2} increased defense
			{3}% reduced damage taken
			Movement effects of fatness are {4}% more punishing
			Effects scale with your obesity
			'''
	}

