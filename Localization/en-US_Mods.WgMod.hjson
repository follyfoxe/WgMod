			'''
			{$CommonItemTooltip.SummonTagDamage}
			Strike enemies to cover them in hot caramel and summon a fat hellish bee to slurp it up!
			Stats scale with your o[c/FFEA00:B][c/696969:E][c/FFEA00:E]sity
			'''
	}

